{
  "name": "@lexmanh/shed-mcp-server",
  "version": "0.2.0-beta.3",
  "description": "MCP server for Shed — exposes disk scan and analysis tools to Claude Desktop and Claude Code",
  "type": "module",
  "bin": {
    "shed-mcp": "dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/server.ts --format esm --clean",
    "dev": "tsup src/server.ts --format esm --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lexmanh/shed-agent": "workspace:^",
    "@lexmanh/shed-core": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lexmanh/shed.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
