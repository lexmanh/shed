{
  "name": "@lxmanh/shed-core",
  "version": "0.0.0",
  "description": "Core logic for Shed: project detection, safety checks, risk classification",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./safety": {
      "types": "./dist/safety/index.d.ts",
      "import": "./dist/safety/index.js"
    },
    "./detectors": {
      "types": "./dist/detectors/index.d.ts",
      "import": "./dist/detectors/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/safety/index.ts src/detectors/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "execa": "^9.5.0",
    "fast-glob": "^3.3.2",
    "pino": "^9.5.0",
    "trash": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fs-fixture": "^2.13.0",
    "memfs": "^4.15.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
