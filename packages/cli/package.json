{
  "name": "@lexmanh/shed-cli",
  "version": "0.2.0-beta.4",
  "description": "Safe disk cleanup CLI for dev machines and Linux servers — git-aware, cross-stack, trash-by-default",
  "type": "module",
  "bin": {
    "shed": "./dist/cli.js"
  },
  "files": ["dist", "package.json"],
  "repository": {
    "type": "git",
    "url": "https://github.com/lexmanh/shed.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@lexmanh/shed-core": "workspace:*",
    "commander": "^12.1.0",
    "conf": "^13.1.0",
    "execa": "^9.5.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
