{
  "name": "@lxmanh/shed-cli",
  "version": "0.1.0-beta.1",
  "description": "Shed CLI — safe, cross-platform disk cleanup for developers",
  "type": "module",
  "bin": {
    "shed": "./dist/cli.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@lxmanh/shed-core": "workspace:*",
    "commander": "^12.1.0",
    "conf": "^13.1.0",
    "execa": "^9.5.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
